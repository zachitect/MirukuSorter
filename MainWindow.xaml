<Window x:Class="MirukuSorter.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:MirukuSorter"
        mc:Ignorable="d"
        Title="MainWindow" Height="400" Width="600"
        MinHeight="400" MinWidth="600"
        >
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <StackPanel Height="40" Margin="10,5,10,5">
            <TextBlock Name ="TextTitle" Foreground ="#424242" HorizontalAlignment="Left" FontSize="16" Text="User Operation Window" FontWeight="Bold"/>
            <TextBlock Name ="TextInstruction" Foreground ="#535353" HorizontalAlignment="Left" FontSize="12"  Text="Please proceed with user operation"/>
        </StackPanel>
        <Grid Grid.Row="1">
            <ListView
                Name="ListViewFiles"
                BorderThickness="0,1,0,1"
                SelectionMode="Single"
                ItemsSource="{Binding MediaFiles}">
                <ListView.View>
                    <GridView AllowsColumnReorder="False">
                        <GridViewColumn Header="File Path" Width="390" DisplayMemberBinding="{Binding MediaPath}"/>
                        <GridViewColumn Header="File Type" Width="100" DisplayMemberBinding="{Binding MediaType}"/>
                        <GridViewColumn Header="Meta Date" Width="100" DisplayMemberBinding="{Binding MediaDate}"/>
                    </GridView>
                </ListView.View>
            </ListView>
        </Grid>
        <Grid Grid.Row="3" Margin="5,5,5,5">
            <Grid.RowDefinitions>
                <RowDefinition Height="40"/>
                <RowDefinition Height="40"/>
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Button Margin="5,5,5,5" Grid.Row="0" Grid.ColumnSpan="2" Name="ButtonScanDirectory" Content="{Binding LoadedDirectory}" Click="ButtonScanDirectory_Click"/>
            <Button Margin="5,5,5,5" Grid.Row="1" Grid.Column="0" Name ="ButtonSortPhotos" Content="Sort Photos" Click="ButtonSortPhotos_Click"/>
            <Button Margin="5,5,5,5" Grid.Row="1" Grid.Column="1" Name ="ButtonSortVideos" Content="Sort Videos" Click="ButtonSortVideos_Click"/>
        </Grid>
    </Grid>
</Window>
